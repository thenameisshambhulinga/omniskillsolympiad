generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                                                          String               @id @default(cuid())
  email                                                       String               @unique
  college                                                     String?
  branch                                                      String?
  year                                                        String?
  siliconPoints                                               Int                  @default(0)
  streak                                                      Int                  @default(0)
  createdAt                                                   DateTime             @default(now())
  image                                                       String?
  fullName                                                    String?
  isOnboarded                                                 Boolean              @default(false)
  bio                                                         String?
  skills                                                      String[]
  role                                                        UserRole             @default(STUDENT)
  omniId                                                      String?              @unique
  careerInterests                                             String[]
  course                                                      String?
  dateOfBirth                                                 String?
  district                                                    String?
  phone                                                       String?
  pincode                                                     String?
  semester                                                    String?
  state                                                       String?
  university                                                  String?
  usn                                                         String?
  accounts                                                    Account[]
  activities                                                  Activity[]
  CompetitionHistory_CompetitionHistory_adminIdToUser         CompetitionHistory[] @relation("CompetitionHistory_adminIdToUser")
  CompetitionHistory_CompetitionHistory_userIdToUser          CompetitionHistory[] @relation("CompetitionHistory_userIdToUser")
  CompetitionProfile_CompetitionProfile_lastUpdatedByIdToUser CompetitionProfile[] @relation("CompetitionProfile_lastUpdatedByIdToUser")
  CompetitionProfile_CompetitionProfile_userIdToUser          CompetitionProfile?  @relation("CompetitionProfile_userIdToUser")
  dailyAttempts                                               DailyAttempt[]
  quizAttempts                                                QuizAttempt[]
  seasonProgress                                              SeasonProgress?
  sessions                                                    Session[]
  skillProgress                                               SkillProgress[]
  submissions                                                 Submission[]
}

model OmniCounter {
  id        Int @id @default(1)
  nextValue Int
}

model QuizAttempt {
  id              String    @id @default(cuid())
  score           Int       @default(0)
  total           Int       @default(0)
  category        String
  createdAt       DateTime  @default(now())
  userId          String
  quizId          String?
  percentage      Float     @default(0)
  startedAt       DateTime  @default(now())
  expiresAt       DateTime?
  submittedAt     DateTime?
  completed       Boolean   @default(false)
  suspicious      Boolean   @default(false)
  tabSwitchCount  Int       @default(0)
  durationMinutes Int       @default(30)
  answersJson     String?
  selectionStatus String    @default("PENDING")
  selectionRank   Int?
  selectionEvaluatedAt DateTime?
  quiz            Quiz?     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id])

  @@unique([userId, quizId])
  @@index([userId])
  @@index([quizId])
  @@index([completed])
}

model SkillProgress {
  id       String @id @default(cuid())
  skill    String
  progress Int
  userId   String
  user     User   @relation(fields: [userId], references: [id])
}

model Quiz {
  id          String       @id @default(cuid())
  title       String
  description String?
  category    String
  difficulty  String
  duration    Int
  createdAt   DateTime     @default(now())
  isActive    Boolean      @default(true)
  totalPoints Int
  isSelectionTest                 Boolean @default(false)
  selectionMinimumPercentage      Float   @default(60)
  selectionMaxTabSwitches         Int     @default(4)
  selectionRequireNonSuspicious   Boolean @default(true)
  selectionShortlistLimit         Int?
  questions   Question[]
  submissions Submission[]
    attempts    QuizAttempt[]
}

model Question {
  id            String   @id @default(cuid())
  quizId        String
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String
  points        Int      @default(1)
  createdAt     DateTime @default(now())
  quiz          Quiz     @relation(fields: [quizId], references: [id])
}

model Submission {
  id          String   @id @default(cuid())
  userId      String
  quizId      String
  score       Int
  submittedAt DateTime @default(now())
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model DailyChallenge {
  id          String          @id @default(cuid())
  dayNumber   Int
  title       String
  description String?
  createdAt   DateTime        @default(now())
  isPublished Boolean         @default(false)
  attempts    DailyAttempt[]
  questions   DailyQuestion[]
}

model DailyQuestion {
  id            String         @id @default(cuid())
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String
  difficulty    String
  challengeId   String
  createdAt     DateTime       @default(now())
  challenge     DailyChallenge @relation(fields: [challengeId], references: [id])
}

model DailyAttempt {
  id             String         @id @default(cuid())
  score          Int
  total          Int
  percentage     Float
  completed      Boolean        @default(false)
  challengeDay   Int
  createdAt      DateTime       @default(now())
  userId         String
  challengeId    String
  expiresAt      DateTime?
  startedAt      DateTime       @default(now())
  submittedAt    DateTime?
  suspicious     Boolean        @default(false)
  tabSwitchCount Int            @default(0)
  challenge      DailyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
}

model SeasonProgress {
  id                String   @id @default(cuid())
  currentDay        Int      @default(1)
  completedDays     Int      @default(0)
  consistencyScore  Float    @default(100)
  averageAccuracy   Float    @default(0)
  weightedRankScore Float    @default(0)
  totalPoints       Int      @default(0)
  eliminated        Boolean  @default(false)
  championBlocked   Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])

  @@index([weightedRankScore])
  @@index([userId])
}

model Activity {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String?
  points      Int      @default(0)
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CompetitionHistory {
  id                                    String                        @id
  userId                                String
  adminId                               String?
  vibgyorStage                          CompetitionVibgyorStage
  omniStep                              CompetitionOmniStep
  assessmentName                        String?
  assessmentScore                       Int?
  judgeEvaluation                       String?
  verificationStatus                    CompetitionVerificationStatus
  siliconPoints                         Int
  remarks                               String?
  evaluator                             String?
  createdAt                             DateTime                      @default(now())
  User_CompetitionHistory_adminIdToUser User?                         @relation("CompetitionHistory_adminIdToUser", fields: [adminId], references: [id])
  User_CompetitionHistory_userIdToUser  User                          @relation("CompetitionHistory_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([userId, createdAt])
  @@index([verificationStatus])
  @@index([vibgyorStage])
}

model CompetitionProfile {
  id                                            String                        @id
  userId                                        String                        @unique
  vibgyorStage                                  CompetitionVibgyorStage       @default(VIOLET)
  omniStep                                      CompetitionOmniStep           @default(O)
  assessmentName                                String?
  assessmentScore                               Int?
  judgeEvaluation                               String?
  verificationStatus                            CompetitionVerificationStatus @default(PENDING)
  siliconPoints                                 Int                           @default(0)
  remarks                                       String?
  evaluator                                     String?
  lastUpdatedById                               String?
  createdAt                                     DateTime                      @default(now())
  updatedAt                                     DateTime
  User_CompetitionProfile_lastUpdatedByIdToUser User?                         @relation("CompetitionProfile_lastUpdatedByIdToUser", fields: [lastUpdatedById], references: [id])
  User_CompetitionProfile_userIdToUser          User                          @relation("CompetitionProfile_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastUpdatedById])
  @@index([userId])
  @@index([verificationStatus])
  @@index([vibgyorStage])
}

enum UserRole {
  ADMIN
  STUDENT
}

enum CompetitionOmniStep {
  O
  M
  N
  I
}

enum CompetitionVerificationStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum CompetitionVibgyorStage {
  VIOLET
  INDIGO
  BLUE
  GREEN
  YELLOW
  ORANGE
  RED
}
model AnnouncementPoster {
  id             String   @id @default(cuid())

  title          String
  subtitle       String
  category       String
  status         String

  imageUrl       String
  mobileImageUrl String?

  ctaLabel       String
  ctaHref        String

  slug           String   @unique

  shortDescription String @default("")
  description      String @default("")
  about            String @default("")

  eligibility      String @default("")
  benefits         String @default("")
  rules            String @default("")
  faq              String @default("")

  venue            String?
  registrationUrl  String?

  registrationDeadline DateTime?
  eventStart           DateTime?
  eventEnd             DateTime?

  gallery          String[]

  placement      String   @default("LOGIN_HERO")
  priority       Int      @default(0)

  isHero         Boolean  @default(false)
  isPublished    Boolean  @default(false)

  publishAt      DateTime @default(now())
  expiresAt      DateTime?

  highlights     String   @default("")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([slug])
  @@index([isPublished])
  @@index([placement])
  @@index([priority])
}